generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ——— Auth.js (NextAuth v5) ———

enum UserRole {
  user
  admin
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  /// Proveedor OAuth usado en el último acceso (referencia UX).
  provider      String?
  role          UserRole  @default(user)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  restaurantClaims    RestaurantClaim[]
  restaurantOwnership RestaurantOwnership[]
  changeRequests      RestaurantChangeRequest[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ——— Restaurantes y ownership ———

model Restaurant {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  category      String
  priceRange    String   @default("$$")
  summary       String?
  address       String?
  lat           Float?
  lng           Float?
  phone         String?
  whatsapp      String?
  scheduleLabel      String?
  /// Horario por día (JSON: `[{ "day": "Lunes", "open": "8:00", "close": "20:00" }, ...]`) cuando existe en DB.
  scheduleStructured Json?
  menuUrl       String?
  instagramUrl  String?
  googleMapsUrl String?
  ratingAverage Float    @default(0)
  reviewsCount  Int      @default(0)
  heroUrl       String?
  gallery       Json?
  offersDelivery       Boolean @default(false)
  acceptsReservations  Boolean @default(false)
  source        String   @default("auto")
  verified      Boolean  @default(false)
  status        String   @default("published")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  claims         RestaurantClaim[]
  ownerships     RestaurantOwnership[]
  changeRequests RestaurantChangeRequest[]

  @@map("restaurants")
}

enum ClaimStatus {
  pending
  approved
  rejected
}

model RestaurantClaim {
  id               String      @id @default(cuid())
  restaurantId     String?
  restaurantSlug   String
  userId           String
  ownerName        String
  ownerPhone       String?
  ownerEmail       String?
  message          String?
  evidenceUrl      String?
  status           ClaimStatus @default(pending)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  restaurant Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: SetNull)
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([restaurantSlug])
  @@index([status])
  @@map("restaurant_claims")
}

enum OwnershipRole {
  owner
  manager
  editor
}

enum OwnershipStatus {
  active
  inactive
}

model RestaurantOwnership {
  id           String            @id @default(cuid())
  restaurantId String
  userId       String
  role         OwnershipRole     @default(owner)
  status       OwnershipStatus   @default(active)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, restaurantId])
  @@map("restaurant_ownerships")
}

enum ChangeRequestStatus {
  pending
  approved
  rejected
}

model RestaurantChangeRequest {
  id           String                @id @default(cuid())
  restaurantId String
  userId       String
  changes      Json
  imageUrls    Json?
  status       ChangeRequestStatus    @default(pending)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("restaurant_change_requests")
}
